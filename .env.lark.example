LARK_APP_ID=cli_xxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxx
# Or provide direct token instead of app id/secret:
# LARK_TENANT_ACCESS_TOKEN=t-xxxxxxxxxxxxxxxx

LARK_BASE_TOKEN=appxxxxxxxxxxxxx
LARK_TABLE_ID=tblxxxxxxxxxxxxx
LARK_ATTACHMENTS_FIELD=Attachments
LARK_NAME_FIELD=OrderNo
LARK_OUTPUT_DIR=./downloads
LARK_PAGE_SIZE=500
LARK_MAX_RETRIES=3
LARK_RETRY_DELAY_MS=1000

# Optional (default is https://open.larksuite.com/open-apis)
# LARK_OPEN_API_BASE=https://open.larksuite.com/open-apis
